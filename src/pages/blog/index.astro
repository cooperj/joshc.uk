---
import { getCollection } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const posts = (
  await getCollection("blog", ({ data }) => {
    return data.draft !== true;
  })
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function groupPostsByYear(
  groupedPosts: typeof posts,
): Array<{ year: number; posts: typeof groupedPosts }> {
  const groups = new Map<number, typeof groupedPosts>();

  for (const post of groupedPosts) {
    const year = post.data.pubDate.getFullYear();
    const existing = groups.get(year);

    if (existing) {
      existing.push(post);
      continue;
    }

    groups.set(year, [post]);
  }

  return Array.from(groups.entries())
    .sort(([yearA], [yearB]) => yearB - yearA)
    .map(([year, yearPosts]) => ({ year, posts: yearPosts }));
}

const postGroups = groupPostsByYear(posts);
---

<BaseLayout pageTitle="Blog" pageDescription="List of blog articles posted">
  <div class="prose">
    <div class="title mb-8">
      <h1 class="text-4xl text-center font-extrabold mb-2">Blog</h1>
    </div>
  </div>

  <section aria-label="Blog posts">
    {
      postGroups.map((group) => (
        <>
          <div class="flex items-center gap-3 mt-8 mb-4">
            <h2 class="text-xl font-bold m-0">{group.year}</h2>
            <div class="h-px flex-1 bg-black-200 dark:bg-black-500" />
          </div>

          {group.posts.map((post) => (
            <a href={`/blog/${post.id}/`}>
              <div class="flex flex-col m-2 border-2 border-black-200 p-2 rounded-xl hover:bg-black-200">
                <div class="flex flex-row">
                  {post.data.icon ? (
                    <img
                      aria-hidden="true"
                      src={post.data.icon}
                      class="rounded-xl h-20 w-20 tablet:h-32 tablet:w-32"
                    />
                  ) : (
                    <img
                      aria-hidden="true"
                      src="/images/no-image.webp"
                      class="rounded-xl h-20 tablet:h-32"
                    />
                  )}
                  <div class="flex flex-col ml-5">
                    <h4 class="title mt-0 font-semibold">{post.data.title}</h4>
                    <p class="date">
                      {post.data.update ? (
                        <>
                          <FormattedDate date={post.data.pubDate} />
                          <span class="italic ml-2">
                            (Updated <FormattedDate date={post.data.update} />)
                          </span>
                        </>
                      ) : (
                        <FormattedDate date={post.data.pubDate} />
                      )}
                    </p>
                    <div class="mt-2 hidden tablet:block max-w-xl laptop:max-w-4xl">
                      <p>{post.data.description}</p>
                    </div>
                  </div>
                </div>
                <div class="mt-2 tablet:hidden">
                  <p>{post.data.description}</p>
                </div>
              </div>
            </a>
          ))}
        </>
      ))
    }
  </section>
</BaseLayout>
