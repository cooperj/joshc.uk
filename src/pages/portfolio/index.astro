---
import { getCollection } from "astro:content";
import ProjectDate from "@/components/ProjectDate.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContentDateValue } from "@/utils/contentDates";

const allProjects = await getCollection("portfolio", ({ data }) => {
  return data.draft !== true;
});

const activeProjects = allProjects
  .filter((p) => p.data.active)
  .sort((a, b) => getContentDateValue(b.data) - getContentDateValue(a.data));

const inactiveProjects = allProjects
  .filter((p) => !p.data.active)
  .sort((a, b) => getContentDateValue(b.data) - getContentDateValue(a.data));
---

<BaseLayout pageTitle="Portfolio" pageDescription="Josh's Portfolio">
  <div class="prose">
    <div class="title mb-8">
      <h1 class="text-4xl text-center font-extrabold mb-2">Portfolio</h1>
    </div>
  </div>

  {
    activeProjects.length > 0 && (
      <section aria-label="Active projects">
        <div class="flex items-baseline gap-3 mb-6 pb-3 border-b border-black-100 dark:border-black-400">
          <h2 class="text-2xl font-semibold m-0">Active Projects</h2>
          <span class="text-xs font-medium uppercase tracking-wider px-2 py-0.5 rounded-full bg-teal-100 dark:bg-teal-800 text-teal-700 dark:text-teal-300">
            Ongoing
          </span>
        </div>
        {activeProjects.map((project) => (
          <a href={`/portfolio/${project.id}/`}>
            <div class="flex flex-col m-2 border-2 border-black-200 p-2 rounded-xl hover:bg-black-200">
              <div class="flex flex-row">
                {project.data.icon ? (
                  <img
                    aria-hidden="true"
                    src={project.data.icon}
                    class="rounded-xl h-20 w-20 tablet:h-32 tablet:w-32"
                  />
                ) : (
                  <img
                    aria-hidden="true"
                    src="/images/no-image.webp"
                    class="rounded-xl h-20 tablet:h-32"
                  />
                )}
                <div class="flex flex-col ml-5">
                  <h4 class="title mt-0 font-semibold">{project.data.title}</h4>
                  <p class="date">
                    <ProjectDate
                      fromDate={project.data.fromDate}
                      pubDate={project.data.pubDate}
                    />
                  </p>
                  <div class="mt-2 hidden tablet:block max-w-xl laptop:max-w-4xl">
                    <p>{project.data.description}</p>
                  </div>
                </div>
              </div>
              <div class="mt-2 tablet:hidden">
                <p>{project.data.description}</p>
              </div>
            </div>
          </a>
        ))}
      </section>
    )
  }

  <section
    aria-label="Previous projects"
    class={activeProjects.length > 0 ? "mt-10" : ""}
  >
    {
      activeProjects.length > 0 && (
        <div class="flex items-baseline gap-3 mb-6 pb-3 border-b border-black-100 dark:border-black-400">
          <h2 class="text-2xl font-semibold m-0">Previous Projects</h2>
        </div>
      )
    }
    {
      inactiveProjects.map((project) => (
        <a href={`/portfolio/${project.id}/`}>
          <div class="flex flex-col m-2 border-2 border-black-200 p-2 rounded-xl hover:bg-black-200">
            <div class="flex flex-row">
              {project.data.icon ? (
                <img
                  aria-hidden="true"
                  src={project.data.icon}
                  class="rounded-xl h-20 w-20 tablet:h-32 tablet:w-32"
                />
              ) : (
                <img
                  aria-hidden="true"
                  src="/images/no-image.webp"
                  class="rounded-xl h-20 tablet:h-32"
                />
              )}
              <div class="flex flex-col ml-5">
                <h4 class="title mt-0 font-semibold">{project.data.title}</h4>
                <p class="date">
                  <ProjectDate
                    fromDate={project.data.fromDate}
                    pubDate={project.data.pubDate}
                  />
                </p>
                <div class="mt-2 hidden tablet:block max-w-xl laptop:max-w-4xl">
                  <p>{project.data.description}</p>
                </div>
              </div>
            </div>
            <div class="mt-2 tablet:hidden">
              <p>{project.data.description}</p>
            </div>
          </div>
        </a>
      ))
    }
  </section>
</BaseLayout>
