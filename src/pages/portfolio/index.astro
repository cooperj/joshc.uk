---
import { getCollection } from "astro:content";
import ProjectCard from "@/components/ProjectCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getContentDateValue } from "@/utils/contentDates";

const allProjects = await getCollection("portfolio", ({ data }) => {
  return data.draft !== true;
});

const activeProjects = allProjects
  .filter((p) => p.data.active)
  .sort((a, b) => getContentDateValue(b.data) - getContentDateValue(a.data));

const inactiveProjects = allProjects
  .filter((p) => !p.data.active)
  .sort((a, b) => getContentDateValue(b.data) - getContentDateValue(a.data));
---

<BaseLayout pageTitle="Portfolio" pageDescription="Josh's Portfolio">
  <div class="prose">
    <div class="title mb-8">
      <h1 class="text-4xl text-center font-extrabold mb-2">Portfolio</h1>
    </div>
  </div>

  {
    activeProjects.length > 0 && (
      <section aria-label="Active projects">
        <div class="flex items-baseline gap-3 mb-6 pb-3 border-b border-black-100 dark:border-black-400">
          <h2 class="text-2xl font-semibold m-0">Active Projects</h2>
          <span class="text-xs font-medium uppercase tracking-wider px-2 py-0.5 rounded-full bg-teal-100 dark:bg-teal-800 text-teal-700 dark:text-teal-300">
            Ongoing
          </span>
        </div>
        {activeProjects.map((project) => (
          <ProjectCard project={project} showUpdate />
        ))}
      </section>
    )
  }

  <section
    aria-label="Previous projects"
    class={activeProjects.length > 0 ? "mt-10" : ""}
  >
    {
      activeProjects.length > 0 && (
        <div class="flex items-baseline gap-3 mb-6 pb-3 border-b border-black-100 dark:border-black-400">
          <h2 class="text-2xl font-semibold m-0">Previous Projects</h2>
          <span class="text-xs font-medium uppercase tracking-wider px-2 py-0.5 rounded-full bg-orange-100 dark:bg-orange-800 text-orange-700 dark:text-orange-300">
            Archive
          </span>
        </div>
      )
    }
    {inactiveProjects.map((project) => <ProjectCard project={project} />)}
  </section>
</BaseLayout>
