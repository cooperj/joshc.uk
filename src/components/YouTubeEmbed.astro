---
import { Icon } from "astro-icon/components";

const { videoId } = Astro.props;
const thumbnailUrl = `https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`;
const watchUrl = `https://www.youtube.com/watch?v=${videoId}`;
const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
---

<div
  class="youtube-consent my-10 rounded-xl overflow-hidden relative"
  data-embed-url={embedUrl}
>
  <img
    src={thumbnailUrl}
    alt="YouTube video thumbnail"
    class="w-full object-cover aspect-video opacity-30 block"
  />
  <div
    class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-6 text-center"
  >
    <Icon
      name="lucide:play"
      class="w-20 h-20"
      aria-hidden="true"
    />

    <h3 class="font-serif text-black-500 dark:text-white-500 mt-2 mb-0">
      This video is hosted by YouTube
    </h3>

    <p class="text-sm text-black-400 dark:text-white-600 max-w-sm mt-0">
      Loading this video will share your data with Google.
    </p>

    <button data-action="embed" class="button">
      Play Video
    </button>

    <a
      href={watchUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-sm underline text-orange-800 dark:text-orange-500 hover:text-orange-600 dark:hover:text-orange-300"
    >
      <Icon name="lucide:external-link" class="inline mr-1" />
      Open on YouTube
    </a>
  </div>
</div>

<script>
  document.querySelectorAll(".youtube-consent").forEach((wrapper) => {
    wrapper
      .querySelector("[data-action='embed']")
      ?.addEventListener("click", () => {
        const embedUrl = (wrapper as HTMLElement).dataset.embedUrl!;
        const iframe = document.createElement("iframe");
        iframe.src = embedUrl;
        iframe.allow =
          "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture";
        iframe.allowFullscreen = true;
        iframe.classList.add("w-full", "aspect-video", "rounded-xl", "my-10");
        wrapper.replaceWith(iframe);
      });
  });
</script>
