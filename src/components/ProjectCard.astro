---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@/components/FormattedDate.astro";
import ProjectDate from "@/components/ProjectDate.astro";
import ContentVisual from "@/components/ContentVisual.astro";

interface Props {
  project: CollectionEntry<"portfolio">;
  showUpdate?: boolean;
}

const { project, showUpdate = false }: Props = Astro.props;
---

<a href={`/portfolio/${project.id}/`}>
  <div
    class="flex flex-col m-2 border-2 border-black-200 p-2 rounded-xl hover:bg-black-200"
  >
    <div class="flex flex-row">
      <ContentVisual
        src={project.data.icon}
        emoji={project.data.emoji ?? project.data.icon}
        class="rounded-xl h-20 w-20 tablet:h-32 tablet:w-32"
      />
      <div class="flex flex-col ml-5">
        <h4 class="title mt-0 font-semibold">{project.data.title}</h4>
        <p class="date">
          <ProjectDate
            fromDate={project.data.fromDate}
            pubDate={project.data.pubDate}
            active={project.data.active}
          />
          {
            showUpdate && project.data.update && (
              <span class="italic ml-2">
                (Updated <FormattedDate date={project.data.update} />)
              </span>
            )
          }
        </p>
        <div class="mt-2 hidden tablet:block max-w-xl laptop:max-w-4xl">
          <p>{project.data.description}</p>
        </div>
      </div>
    </div>
    <div class="mt-2 tablet:hidden">
      <p>{project.data.description}</p>
    </div>
  </div>
</a>
